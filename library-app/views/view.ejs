<%- include('partials/header', { title: book ? book.title : 'Книга не найдена' }) %>

    <% if (book) { %>
        <h1>
            <%= book.title %>
        </h1>
        <% if (book.fileCover) { %>
            <img src="<%= book.fileCover %>" class="img-thumbnail mb-3" style="max-width:200px;">
            <% } %>
                <p><strong>Автор:</strong>
                    <%= book.authors %>
                </p>
                <p>
                    <%= book.description %>
                </p>
                <p><strong>Просмотров:</strong>
                    <%= counter %>
                </p>

                <% if (book.fileBook) { %>
                    <p><a class="btn btn-outline-primary" href="<%= book.fileBook %>" download>Скачать книгу</a></p>
                    <% } %>

                        <% if (book.favorite) { %>
                            <span class="badge bg-success">★ Избранное</span>
                            <% } %>

                                <div class="mt-3">
                                    <a class="btn btn-primary" href="/books/update/<%= book.id %>">Редактировать</a>
                                    <a class="btn btn-secondary" href="/books">Назад</a>
                                </div>
                                <% } else { %>
                                    <div class="alert alert-danger">Книга не найдена</div>
                                    <% } %>

                                        <h3 class="mt-4">Комментарии</h3>

                                        <div id="comments">
                                            <% comments.forEach(c=> { %>
                                                <div class="border p-2 mb-2">
                                                    <strong>
                                                        <%= c.user %>
                                                    </strong>: <%= c.text %>
                                                </div>
                                                <% }) %>
                                        </div>

                                        <form id="commentForm">
                                            <input type="text" id="commentText" class="form-control mb-2"
                                                placeholder="Комментарий">
                                            <button class="btn btn-primary">Отправить</button>
                                        </form>


                                        </div>

                                        <script src="/socket.io/socket.io.js"></script>
                                        <script>
                                            const socket = io();
                                            const bookId = "<%= book.id %>";
                                            const user = "<%= user?.email || 'Гость' %>";

                                            socket.emit("joinBook", bookId);

                                            const form = document.getElementById("commentForm");
                                            const input = document.getElementById("commentText");
                                            const commentsDiv = document.getElementById("comments");

                                            form.addEventListener("submit", (e) => {
                                                e.preventDefault();

                                                const text = input.value.trim();
                                                if (!text) return;

                                                socket.emit("newComment", { bookId, user, text });
                                                input.value = "";
                                            });

                                            socket.on("commentAdded", (data) => {
                                                const div = document.createElement("div");
                                                div.className = "border p-2 mb-2";
                                                div.innerHTML = `<strong>${data.user}</strong>: ${data.text}`;
                                                commentsDiv.appendChild(div);
                                            });
                                        </script>

                                        </body>

                                        </html>